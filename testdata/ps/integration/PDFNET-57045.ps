%!
%%DocumentPaperSizes: A4
%%Orientation:Portrait
%%BoundingBox: 0 0 596 743

    0        0  translate 

%!

 /fontprob 10 def

 /fontniv 8  def

 /fontlab 9  def

 /con { 2.54 div 72 mul} def

 /cen { 
        newpath 
          con 0 360 arc 
          setlinewidth 
        stroke 
      } def 

 /cir { 
        gsave 
         newpath 
           con 0 360 arc 
           setlinewidth 
           [3 3] 0 setdash 
         stroke 
        grestore 
      } def 

 /rad { 
        gsave 
         rotate 
         newpath 
           0 exch con moveto 
           0 exch con lineto 
           setlinewidth 
           [3 3] 0 setdash 
         stroke 
        grestore 
      } def 

 /box { 
        gsave 
         rotate 
         newpath 
           con        0 exch moveto 
           con  2 div 0      rlineto 
           con        0 exch rlineto 
           con -1 mul 0      rlineto 
           con -1 mul 0 exch rlineto 
         closepath 
         gsave 
           setgray 
           fill 
         grestore 
           setlinewidth 
           stroke 
        grestore 
      } def 

  /probdir { gsave 
               /Times-Roman findfont 
                fontprob scalefont 
                setfont 
                dup -1  mul    rotate 
                exch con 0 exch translate 
                dup        rotate 

                dup cos 0 ge 
                { 0  0   moveto } 
                { 0 fontprob -1 mul  moveto } 
                ifelse 

                sin 0 ge 
                { dup stringwidth pop pop }
                { dup stringwidth pop 
                  -1 mul 0 rmoveto } 
                ifelse 
               show 

              grestore 
            } def  

  /blank {  
            gsave 
              newpath 
                0   0             moveto 
                dup 0    exch     rlineto 
                exch     0        rlineto 
                0   exch -1   mul rlineto 
              closepath 
              1 setgray 
              fill 
            grestore 
         }  def   

  /probniv {  
              gsave 
                /Times-Roman findfont 
                 fontniv  scalefont 
                 setfont 
                dup rotate  

                -1 mul cos 0 gt  
                { con fontniv 0.5 mul sub  
                    0 exch translate}  
                { con fontniv 0.4 mul add  
                    0 exch translate  
                  180 rotate } 
                ifelse 

                dup stringwidth pop 
                    -0.5 mul 0 translate 
                dup stringwidth pop 
                    fontniv blank 
                0 0 moveto
                show
              grestore 
           }  def 

   /labniv { 
              gsave  
                /Times-Roman findfont 
                 fontlab   scalefont  
                 setfont              
                 con 0 exch translate 
                 dup stringwidth pop  
                  -1 mul 0  translate 
                 0 0  moveto          
                 show 
              grestore 
           }  def 

 gsave 
