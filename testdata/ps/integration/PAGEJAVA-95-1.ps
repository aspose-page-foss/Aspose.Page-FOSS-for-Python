%!PS-
%%DocumentFonts: atend
%%Creator: SAPscript, SAP R/3
%%EndComments
/SAPdict 12 dict def
/SAPencode
{ SAPdict begin
  /basefontname exch def
  /SAPfontname exch def
  /basefontdict basefontname findfont def
  /SAPfont      basefontdict maxlength dict def
  basefontdict
  { exch dup /FID ne
    { dup /Encoding eq
      { exch dup length array copy SAPfont 3 1 roll put }
      { exch SAPfont 3 1 roll put }
      ifelse }
    { pop pop }
    ifelse }
  forall
  SAPfont /FontName SAPfontname put
  SAPcodes aload pop
  SAPcodes length 2 idiv
    { SAPfont /Encoding get 3 1 roll put } repeat
    SAPfontname SAPfont definefont pop
end } def
/SAPcodes mark
counttomark array astore exch pop def
/sp {showpage} def
/ff {findfont} def
/sc {scalefont} def
/sf {setfont} def
/tw {20 div} def
/su {tw /SU exch def} def
/s1 {0 SU rmoveto} def
/s2 {0 SU neg rmoveto} def
/w1 {SW 0 8#040} def
/w2 {widthshow} def
/sw {/SW exch tw ( ) stringwidth pop sub def} def
/s {show} def
/op {tw /h exch def} def
/ol {90 rotate /h 0 def} def
/mt {tw exch tw neg h add moveto} def
0 setlinecap
0 setgray
/up {tw /ULp exch def} def
/ut {tw /ULt exch def} def
/ug {100 div /ULg exch def} def
/u1 {tw /ULw exch def
    currentpoint /ULy1 exch def /ULx1 exch def
    newpath ULx1 ULy1 moveto 0 ULp rmoveto
    ULw 0 rlineto closepath ULt setlinewidth
    ULg setgray stroke 0 setgray ULx1 ULy1 moveto} def
/u2 {currentpoint /ULy1 exch ULp add def /ULx1 exch def} def
/u3 {currentpoint /ULy2 exch def /ULx2 exch def
    newpath ULx2 ULy2 moveto 0 ULp rmoveto
    ULx1 ULy1 lineto closepath ULt setlinewidth
    ULg setgray stroke 0 setgray ULx2 ULy2 moveto} def
/StartGR { /GRsave save def 0 setgray 0 setlinecap 1 setlinewidth
    0 setlinejoin 10 setmiterlimit [] 0 setdash
    newpath /showpage {} def /copypage {} def /erasepage {} def
    /initgraphics {} def /initclip {} def /initmatrix {} def
    mark } bind def
/EndGR { GRsave restore cleartomark } bind def
/SetInputTray { /Intraynum exch def
mark { statusdict begin Intraynum setpapertray end }
stopped cleartomark } def
/SetPrintMode { /Printmode exch def
mark { statusdict begin
  Printmode 0 eq {false setduplexmode} if
  Printmode 1 eq {true setduplexmode false settumble} if
  Printmode 2 eq {true setduplexmode true settumble} if end}
stopped cleartomark } def
%%EndProlog
%@(#)fngb.ps	20.4	SAP	96/08/12

%*******************************************************************************
%
%	SAP AG Walldorf
%	Systeme, Anwendungen und Produkte in der Datenverarbeitung
%
%	(C) Copyright SAP AG 1996
%
%*******************************************************************************
%
%	PostScript Font Definition Program
%
%*******************************************************************************
%
%	File Name:	fngb.ps
%
%	Code System:	Simplified Chinese GB2312 Code
%
%	Font Name:	Fixed-Medium-GB-H
%
%	Usage:		% lp fngb.ps [file ...]
%
%*******************************************************************************

15 dict begin

	% strcat
	% suffix
	% fontalias

	% StandardFontMatrix
	% HalfFontMatrix
	% StandardFontBBox

	% basefont
	% compfont1
	% compfont2
	% compfont
	% newfont

	% UND.BuildChar
	% CS0.BuildChar
	% CS1.BuildChar
	% CS2.BuildChar

%-------------------------------------------------------------------------------
%
%	PRIVATE OPERATOR
%
%		strcat
%		suffix
%		fontalias
%
%-------------------------------------------------------------------------------

/strcat
{
  exch 2 copy				% s2 s1 s2 s1
  length dup 5 1 roll exch length	% len1 s2 s1 len1 len2
  add string				% len1 s2 s1 S
  dup 3 1 roll				% len1 s2 S s1 S
  copy pop				% len1 s2 S
  dup 4 1 roll				% S len1 s2 S
  3 1 roll				% S S len1 s2
  putinterval				% S

} bind def

%-------------------------------------------------------------------------------

/suffix
{
  exch 32 string cvs exch strcat cvn
} bind def

%-------------------------------------------------------------------------------

/fontalias
{
  findfont dup maxlength dict begin
  {
    1 index /FID ne 2 index /UniqueID ne and
    { def }{ pop pop } ifelse
  } forall
  currentdict end
  definefont pop
} bind def

%-------------------------------------------------------------------------------
%
%	FONT MATRIX
%	FONT BOUNDING BOX
%
%		StandardFontMatrix
%		HalfFontMatrix
%		StandardFontBBox
%
%-------------------------------------------------------------------------------

/StandardFontMatrix	[ 1   0 0 1 0 0 ]	readonly def
/HalfFontMatrix		[ 0.5 0 0 1 0 0 ]	readonly def
/StandardFontBBox	[ 0 -120 1000 880 ]	readonly def

%-------------------------------------------------------------------------------
%
%	BASE FONT ( Font Type 3 )
%
%		basefont
%
%		bitmap buildchar uniqueid fontname fontmatrix => -
%
%-------------------------------------------------------------------------------

/basefont
{
  9 dict begin

    % Entries for any FontType

    /FontType		3			def
    /FontMatrix		exch			readonly def
    /FontName		exch			def
    /WMode		0			def

    % Entries for Base FontType

    /Encoding		StandardEncoding	readonly def
    /FontBBox		StandardFontBBox	readonly def
    /UniqueID		exch			def

    % Entries for FontType 3

    /BuildChar		exch			def

    % Private Entries

    /Bitmap		exch			readonly def

  currentdict end dup /FontName get exch definefont pop

} bind def

%-------------------------------------------------------------------------------
%
%	COMPOSITE FONT ( Code Set 1 )
%
%		compfont1
%
%		fontname => -
%
%-------------------------------------------------------------------------------

/compfont1
{
  8 dict begin

    % Entries for any FontType

    /FontType		0			def
    /FontMatrix		StandardFontMatrix	readonly def
    /FontName		exch			def
    /WMode		0			def

    % Entries for FontType 0

    /FMapType		2			def

    /Encoding
    [
      16#A1 1 16#FE { 16#A1 sub } for
    ]						readonly def

    /FDepVector
    [
      16#A1 1 16#FE
      {
        16 2 string cvrs FontName (.) suffix exch suffix findfont
      } for
    ]						readonly def

  currentdict end dup /FontName get exch definefont pop

} bind def

%-------------------------------------------------------------------------------
%
%	COMPOSITE FONT ( Code Set 2 )
%
%		compfont2
%
%		fontname => -
%
%-------------------------------------------------------------------------------

/compfont2
{
  8 dict begin

    % Entries for any FontType

    /FontType		0			def
    /FontMatrix		StandardFontMatrix	readonly def
    /FontName		exch			def
    /WMode		0			def

    % Entries for FontType 0

    /FMapType		2			def
    /Encoding		[ 0 ]			readonly def

    /FDepVector
    [
      FontName (.SS2) suffix findfont
    ]						readonly def

  currentdict end dup /FontName get exch definefont pop

} bind def

%-------------------------------------------------------------------------------
%
%	COMPOSITE FONT ( Main Font )
%
%		compfont
%
%		fontname => -
%
%-------------------------------------------------------------------------------

/compfont
{
  9 dict begin

    % Entries for any FontType

    /FontType		0			def
    /FontMatrix		StandardFontMatrix	readonly def
    /FontName		exch			def
    /WMode		0			def

    % Entries for FontType 0

    /FMapType		6			def
    /Encoding		[ 0 1 2 3 4 5 ]		readonly def

    /FDepVector
    [
      FontName (.CS0) suffix findfont		% 00 ... 7F
      FontName (.UND) suffix findfont		% 80 ... 8D
      FontName (.CS2) suffix findfont		% 8E
      FontName (.UND) suffix findfont		% 8F ... A0
      FontName (.CS1) suffix findfont		% A1 ... FE
      FontName (.UND) suffix findfont		% FF
    ]						readonly def

    /SubsVector		<00800E01125E>		readonly def

  currentdict end dup /FontName get exch definefont pop

} bind def

%-------------------------------------------------------------------------------
%
%	FONT CONSTRUCTOR
%
%		newfont
%
%		fontname bitmap0 bitmap1 uniqueid => -
%
%-------------------------------------------------------------------------------

/newfont
{
  4 dict begin

    /uniqueid	exch	def
    /bitmap1	exch	def
    /bitmap0	exch	def
    /fontname	exch	def

    % Base Font ( Undefined Font )

    []				% bitmap
    /UND.BuildChar load		% buildchar
    uniqueid			% uniqueid
    fontname (.UND) suffix	% fontname
    HalfFontMatrix		% fontmatrix
    basefont

    /uniqueid uniqueid 1 add def

    % Base Font ( Code Set 0 )

    bitmap0			% bitmap
    /CS0.BuildChar load		% buildchar
    uniqueid			% uniqueid
    fontname (.CS0) suffix	% fontname
    HalfFontMatrix		% fontmatrix
    basefont

    /uniqueid uniqueid 1 add def

    % Base Font ( Code Set 1 )

    16#A1 1 16#FE
    {
      dup 16 2 string cvrs exch

      16#A1 sub bitmap1 exch get		% bitmap
      /CS1.BuildChar load			% buildchar
      uniqueid					% uniqueid
      fontname (.CS1.) suffix 5 -1 roll suffix	% fontname
      StandardFontMatrix			% fontmatrix
      basefont

      /uniqueid uniqueid 1 add def
    } for

    % Base Font ( Code Set 2 )

    bitmap0			% bitmap
    /CS2.BuildChar load		% buildchar
    uniqueid			% uniqueid
    fontname (.CS2.SS2) suffix	% fontname
    HalfFontMatrix		% fontmatrix
    basefont

    /uniqueid uniqueid 1 add def

    % Composite Font ( Code Set 1 )

    fontname (.CS1) suffix compfont1	

    % Composite Font ( Code Set 2 )

    fontname (.CS2) suffix compfont2

    % Composite Font ( Main Font )

    fontname compfont

  end

} bind def

%-------------------------------------------------------------------------------
%
%	BUILD CHARACTER OPERATOR
%
%		UND.BuildChar
%		CS0.BuildChar
%		CS1.BuildChar
%		CS2.BuildChar
%
%-------------------------------------------------------------------------------

/UND.BuildChar
{
  pop pop
  1 0 setcharwidth
} bind def

%-------------------------------------------------------------------------------

/CS0.BuildChar
{
  1 0 setcharwidth

  dup 16#00 ge exch dup 16#7F le 3 -1 roll and
  { exch /Bitmap get exch get }
  { pop pop {<>} }
  ifelse

  12 24 true [16 0 0 -24 -2 21] 5 -1 roll imagemask
} bind def

%-------------------------------------------------------------------------------

/CS1.BuildChar
{
  1 0 setcharwidth

  dup 16#A1 ge exch dup 16#FE le 3 -1 roll and
  { 16#A1 sub exch /Bitmap get exch get }
  { pop pop {<>} }
  ifelse

  24 24 true [24 0 0 -24 0 21] 5 -1 roll imagemask
} bind def

%-------------------------------------------------------------------------------

/CS2.BuildChar
{
  1 0 setcharwidth

  dup 16#80 ge exch dup 16#FF le 3 -1 roll and
  { exch /Bitmap get exch get }
  { pop pop {<>} }
  ifelse

  12 24 true [16 0 0 -24 -2 21] 5 -1 roll imagemask
} bind def

