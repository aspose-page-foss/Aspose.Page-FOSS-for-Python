/CenterShow
{ dup nstr cvs stringwidth pop
2 div dup /haba exch def neg 0 rmoveto prt-n haba neg 0 rmoveto
} def

/RightShow
{ dup dup nstr cvs stringwidth pop
 neg 0 rmoveto prt-n
} def

/LeftShow
{ dup dup nstr cvs stringwidth pop
 exch prt-n neg 0 rmoveto
} def

/drawarrow
{
moveto
gsave
-0.5 1 rlineto
0.5 -1 rmoveto
2.5 5 rlineto
10 0 rlineto
.1 setlinewidth
stroke
grestore
2.5 5.5 rmoveto
Subfont setfont
show
Mainfont setfont
newpath
} def

/drawarrow2
{
moveto
gsave
0.5 1 rlineto
-0.5 -1 rmoveto
-2.5 5 rlineto
-10 0 rlineto
.1 setlinewidth
stroke
grestore
-12.5 5.5 rmoveto
Subfont setfont
show
Mainfont setfont
newpath
} def

/Init
{
% Line drawing
.3 setlinewidth
150 0 moveto
-150 0 rlineto
0 100 rlineto
gsave
150 0 rlineto
closepath
.95 setgray fill

150 0 moveto
xbrrd xzero sub xspan xzero sub div 150 mul 150 sub 0 rlineto
0 100 rlineto
150 100 lineto
closepath
.80 setgray fill

grestore
stroke

% Put x-pitch
0 0 moveto
xzero xpitch xspan xpitch sub {
xspan xzero sub xpitch div 150 exch div 0 rmoveto
0 1 rlineto 0 -1 rmoveto
} for
stroke

% Put y-pitch
0 0 moveto
yzero ypitch yspan ypitch sub {
yspan yzero sub ypitch div 100 exch div 0 exch rmoveto
-1 0 rlineto 1 0 rmoveto
} for
stroke

% Put y-pitch(sub)
0 0 moveto
yzero2 ypitch2 yspan2 ypitch2 sub {
yspan2 yzero2 sub ypitch2 div 100 exch div 0 exch rmoveto
1 0 rlineto -1 0 rmoveto
} for
stroke

% MCR line
newpath
nmcr 0 moveto
0 100 rlineto
.1 setlinewidth
stroke
nmcr 0 moveto
0 100 rmoveto
-3 1 rmoveto
Subfont setfont
(CMCR) show
Mainfont setfont

% Put x-axis value
0 -6 moveto
xzero xpitch xspan {
CenterShow
xspan xzero sub xpitch div 150 exch div 0 rmoveto
} for

% Put y-axis value
-2 -1 moveto
yzero ypitch yspan {
RightShow
yspan yzero sub ypitch div 100 exch div 0 exch rmoveto
} for

% Put y-axis value(sub)
2 -1 moveto
yzero2 ypitch2 yspan2 {
dup yzero2 gt {LeftShow} {} ifelse
yspan2 yzero2 sub ypitch2 div 100 exch div 0 exch rmoveto
} for

% Put x-axis comment
0 -10 moveto
(Engine Speed) dup stringwidth pop
2 div 75 exch sub 0 rmoveto show
( [min) show
Subfont setfont
0 2 rmoveto (-1) show
Mainfont setfont
0 -2 rmoveto (]) show

% Put y-axis comment
90 rotate
0 15 moveto
ycom dup stringwidth pop
2 div 50 exch sub 0 rmoveto show
-90 rotate

% Put y-axis unit1
-20 103 moveto
( [) show
Subfont setfont
0 2 rmoveto (+) show
(+) stringwidth pop neg -2 rmoveto (-) show
Mainfont setfont
yunit show
Subfont setfont
0 2 rmoveto yunitsub show
Mainfont setfont
0 -2 rmoveto (]) show

% Put y-axis unit2
0 103 moveto
( [) show
Subfont setfont
0 2 rmoveto (+) show
(+) stringwidth pop neg -2 rmoveto (-) show
Mainfont setfont
yunit2 show
Subfont setfont
0 2 rmoveto yunit2sub show
Mainfont setfont
0 -2 rmoveto (]) show

% Put graph comment
0 114 moveto
comment dup stringwidth pop
2 div 75 exch sub 0 rmoveto show
0 0 moveto
} def

/Init2
{
-15 119 moveto
185 0 rlineto
.2 setlinewidth
stroke
Mainfont setfont
-15 134 moveto
(Hull No.:  ) dup stringwidth pop exch show neg -4 rmoveto
(Engine type: ) dup stringwidth pop exch show neg -4 rmoveto
(CMCR:  ) dup stringwidth pop exch show
Subfont setfont
0 2 rmoveto (-1) dup stringwidth pop exch show add neg -4 rmoveto
Mainfont setfont 0 -2 rmoveto
(Classification society: ) dup stringwidth pop exch show neg -4 rmoveto
165 4 rmoveto
(page ) show
prt-n
135 134 moveto
() show
0 0 moveto
} def

