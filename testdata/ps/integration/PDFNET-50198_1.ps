%!PS-Adobe-3.0
%%Pages: (atend)
%%EndComments
% graph initalize
/nstr 7 string def
/haba 0 def
/int 0 def
/Mainfont /Courier findfont 4 scalefont def
/Mainfont2 /Courier findfont 3 scalefont def
/Subfont /Courier findfont 2 scalefont def
/Subsubfont /Courier findfont 1.5 scalefont def
/Taufont /Symbol findfont 3 scalefont def

/mm 72 25.4 div def

/prt-n
{ nstr cvs show } def

/dia 20 def
/radius dia 2 div def
/NoOfBlade 0 def
/CenterOfProp {145 95} def
/Offset    0.0 def
/putprop {
0.2 setlinewidth
CenterOfProp translate
-1 Offset mul rotate
0 360 NoOfBlade div 359 {
pop
0 0 moveto
0 10 93.5 div radius mul rlineto
10 93.5 div radius mul 5  93.5 div radius mul 35  93.5 div radius mul 10 93.5 div radius mul 35 93.5 div radius mul 40 93.5 div radius mul rcurveto
0 25 93.5 div radius mul -20 93.5 div radius mul 35 93.5 div radius mul -35 93.5 div radius mul 40 93.5 div radius mul rcurveto
gsave closepath
1. setgray fill
grestore
0. setgray
stroke
-360 NoOfBlade div rotate
0 0 moveto
0 90 93.5 div radius mul rmoveto
-15 93.5 div radius mul 5 93.5 div radius mul -30 93.5 div radius mul 0 -30 93.5 div radius mul -5 93.5 div radius mul rcurveto
0 -5 93.5 div radius mul 5 93.5 div radius mul -5 93.5 div radius mul 10 93.5 div radius mul -10 93.5 div radius mul rcurveto
5 93.5 div radius mul -5 93.5 div radius mul 10 93.5 div radius mul -15 93.5 div radius mul 10 93.5 div radius mul -25 93.5 div radius mul rcurveto
0 -50 93.5 div radius mul rlineto
gsave
10 93.5 div radius mul 0 rlineto closepath
1. setgray fill
grestore
0. setgray
stroke
} for
0 0 25 93.5 div radius mul 0 360 arc
gsave
1. setgray fill
grestore
.0 setgray
stroke
0 360 NoOfBlade div 359 {
0 0 moveto
0 radius 5 add rlineto
0.1 setlinewidth
[10 1 1 1] 5 setdash
stroke
-360 NoOfBlade div rotate
} for
Offset rotate
Offset 0 ne
{0 0 moveto
0 radius 5 add rlineto
stroke
[] 0 setdash
0 0 radius 2 add 90 Offset sub 10 sub 100 arc
-1 radius 2.5 add moveto
1 -0.5 rlineto
-1 -0.5 rlineto
stroke
Offset -1 mul rotate
1 radius 2.5 add moveto
-1 -0.5 rlineto
1 -0.5 rlineto
stroke
2 radius 3 add moveto
Mainfont setfont
Offset prt-n
(deg.) show
Offset rotate
} if
0.2 setlinewidth
CenterOfProp exch -1 mul exch -1 mul translate
} def
/SREONshow
{
25 110.5 moveto
Mainfont2 setfont
(including variable crank inertia) show
} def

/HarmShow
{
25 108 moveto
Mainfont2 setfont
(harmonics: ue_06_1) show
} def
/MisHarmShow
{
25 105.5 moveto
Mainfont2 setfont
(misfiring: mf_ue_06_1) show
} def
