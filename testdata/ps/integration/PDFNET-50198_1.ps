/Reset {0.0 0.0 0.0 setrgbcolor} def
/SetRed {1.0 0.0 0.0 setrgbcolor} def
/SetGre {0.0 1.0 0.0 setrgbcolor} def
/SetBlu {0.0 0.0 1.0 setrgbcolor} def
/SetYel {1.0 1.0 0.0 setrgbcolor} def
/SetCya {0.0 1.0 1.0 setrgbcolor} def
/SetMag {1.0 0.0 1.0 setrgbcolor} def
/DrawDia {.1 setlinewidth 0.0 0.5 rlineto -0.5 -0.5 rlineto 0.5 -0.5 rlineto 0.5 0.5 rlineto -0.5 0.5 rlineto stroke} def
/DrawTri {.1 setlinewidth 0.0 0.5 rlineto -0.5 -0.7 rlineto 1.0 0.0 rlineto -0.5 0.7 rlineto stroke} def
/DrawSqu {.1 setlinewidth 0.0 0.4 rlineto -0.4 0.0 rlineto 0.0 -0.8 rlineto 0.8 0.0 rlineto 0.0 0.8 rlineto -0.4 0.0 rlineto stroke} def
/PT1 {moveto SetRed DrawDia Reset} def
/PT2 {moveto SetGre DrawTri Reset} def
/PT3 {moveto SetBlu DrawSqu Reset} def
/PT4 {moveto SetYel DrawDia Reset} def
/PT5 {moveto SetCya DrawTri Reset} def
/PT6 {moveto SetMag DrawSqu Reset} def
/PutLegend1 {153 96 moveto SetRed DrawDia Reset} def
/PutLegend2 {153 92 moveto SetGre DrawTri Reset} def
/PutLegend3 {153 88 moveto SetBlu DrawSqu Reset} def
/PutLegend4 {153 84 moveto SetYel DrawDia Reset} def
/PutLegend5 {153 80 moveto SetCya DrawTri Reset} def
/PutLegend6 {153 76 moveto SetMag DrawSqu Reset} def
/PROTDIA {0.5 0 rmoveto -0.5 0.5 rlineto -0.5 -0.5 rlineto 0.5 -0.5 rlineto closepath fill} def
/SHOWINFO {.1 setlinewidth [0.3 0.7] 0 setdash 0 moveto 0 exch rlineto stroke [] 0 setdash} def
/SHOWINFOCOM {-1 add 1 moveto 90 rotate Subfont setfont (No.) show prt-n (Cyl. ) show dup prt-n (-) show 1 add prt-n Mainfont setfont -90 rotate} def

