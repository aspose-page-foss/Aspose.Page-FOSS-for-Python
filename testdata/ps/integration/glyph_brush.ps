<<
/PatternType 1
/PaintType 1
/TilingType 1
/BBox [0.0 0.0 100.0 100.0]
/XStep 100.0
/YStep 100.0
/PaintProc
{
begin
/DeviceRGB setcolorspace
0.0 0.0 translate
100.0 100.0 scale
<<
/ImageType 1
/Width 100  /Height 100
/BitsPerComponent 8
/Decode [0 1 0 1 0 1]
/ImageMatrix [100 0 0 100 0 0]
/DataSource ImageDS0

>> image
end
} bind
