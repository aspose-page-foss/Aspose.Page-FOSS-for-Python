      32 96 moveto
      224 96 lineto
   stroke
   1 setlinewidth
grestore

% TEXT
0 setgray
/Helvetica-Bold findfont [34 0 0 -34 0 0] makefont setfont
   gsave
      182 139 moveto (ncc) tgifcentertext show
   grestore

grestore
tgifsavedpage restore
end
