%!PS

%	This example appears in the introductory section 
%	of Chapter 7 - "Arcs and Curves".
%

/inch { 72 mul } def		%  define inch procedure
newpath				%  initialize path
4.25 inch 5.5 inch		%  x y coordinates of center of circle
4.0 inch			%  radius of circle
0 360 arc			%  start and end angles and draw
closepath			%  finish circle
0.0 1.0 0.0 setrgbcolor		%  set green color
fill				%  fill the circle
showpage			%  display page
