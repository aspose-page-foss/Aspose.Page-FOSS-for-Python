%!PS

%	This example appears in section "PAC-MAN"
%	in Chapter 7 - "Arcs and Curves".
%

/inch { 72 mul } def			%  define inch procedure
newpath					%  ensure new path
4.25 inch 5.5 inch moveto
4.25 inch 5.5 inch 4 inch 45 315 arc
closepath				%  finish the shape
0.5 inch setlinewidth			%  fat line width
stroke					%  paint outline
showpage				%  display page
