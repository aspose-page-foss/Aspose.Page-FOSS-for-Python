%!PS			%  PostScript "magic number"

%	This example appears in section "Basic Graphics - A Triangle" in
%	Chapter 1 - "Introducing PostScript".
%

72 144 moveto		%  set initial point
306 648 lineto		%  add line segment
540 144 lineto		%  add another line segment
closepath		%  finish the shape
stroke			%  paint the path
showpage		%  display page
