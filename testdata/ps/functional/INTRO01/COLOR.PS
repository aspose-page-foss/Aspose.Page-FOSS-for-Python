%!PS

%	This example appears in section "Color and Patterns" in
%	Chapter 1 - "Introducing PostScript".
%

/inch { 72 mul } def		%  define inch procedure
4.25 inch 5.5 inch		%  (x, y) coordinates of center
4.0 inch 0 360 arc		%  4 inch circle
closepath			%  finish circle
0.0 1.0 0.0 setrgbcolor		%  beginner's green
fill				%  fill circle
showpage			%  display page
