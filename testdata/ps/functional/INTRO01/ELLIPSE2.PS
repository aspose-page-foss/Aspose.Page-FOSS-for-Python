%!PS

%	This example appears in section "Rotating the Coordinate System" in
%	Chapter 1 - "Introducing PostScript".
%

/inch { 72 mul } def		%  define inch procedure
4.25 inch 5.5 inch translate	%  origin to center of page
45 rotate			%  rotate image by 45 degrees
1 2 scale			%  scale y axis of user space
0 0 2 inch 0 360 arc		%  draw an ellipse
closepath			%  finish the shape
0.5 inch setlinewidth		%  set fat line width
stroke				%  stroke the path
showpage			%  display page
