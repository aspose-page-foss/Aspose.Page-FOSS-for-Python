%!PS

%	This example appears in section "Transformations" in
%	Chapter 1 - "Introducing PostScript".
%

/inch { 72 mul } def		%  define inch procedure
1 inch 2 inch moveto		%  set initial point
4.25 inch 9 inch lineto		%  add line segment
7.5 inch 2 inch lineto		%  add another line segment
closepath			%  finish the shape
stroke				%  paint the path
showpage			%  display page
