%!PS

%	This example appears in the introductory section
%	of Chapter 8 - "Clipping".
%

/inch { 72 mul } def		%  define inch procedure
4.25 inch 5.5 inch translate	%  origin to center of page
0 1 72 {			%  start for loop
	1 inch 0 moveto		%  set current point
	3.125 inch 0 rlineto	%  add line segment to path
	5 rotate		%  rotate coordinate system
} for				%  end for loop
stroke				%  stroke the lines
showpage			%  display page
