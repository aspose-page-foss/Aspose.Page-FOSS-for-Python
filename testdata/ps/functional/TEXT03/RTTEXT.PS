%!PS

%	This example appears in section "Justification Operations"
%	in Chapter 3 - "Text".
%

/inch { 72 mul } def		%  define inch procedure

/right_show {			%  stack = x  y  (string)
	dup			%  make copy of string
	stringwidth pop		%  compute string width
	4 -1 roll exch sub	%  decrement x position
	3 -1 roll moveto	%  set current point
	show			%  display the string
} def

/Palatino-Roman findfont	%  obtain font
1 inch scalefont		%  scale font to required size
setfont				%  set into graphics state
8 inch 5.5 inch			%  current point
(Right Text) right_show		%  show string at right of page
showpage			%  display page
