%!PS

%	This example appears in section "Clipping with Character
%	Paths" in Chapter 3 - "Text".
%

/inch { 72 mul } def		%  define inch procedure
/Palatino-Bold findfont		%  set required font
12 inch scalefont setfont
1 inch 1 inch moveto (S) show	%  display the character
showpage			%  display page
