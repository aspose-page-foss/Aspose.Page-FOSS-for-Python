%!PS

%	This example appears in section "Stroking Character Paths"
%	in Chapter 3 - "Text".
%

/inch { 72 mul } def		%  define inch procedure
/Palatino-Roman findfont	%  choose large font
13.5 inch scalefont setfont
0.25 inch 0.75 inch moveto	%  set current point
0.75 inch setlinewidth		%  fat line width
(P) false charpath		%  get outline for "P"
stroke				%  stroke outline
showpage			%  display page
