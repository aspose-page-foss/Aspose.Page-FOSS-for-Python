%!PS

%	This example appears in section "Selecting Fonts in PostScript
%	Level 2" in Chapter 3 - "Text".
%
%	Caveats:	Requires PostScript Level 2.

/inch { 72 mul } def		%  define inch procedure
/Palatino-Roman			%  name of required font
2.25 inch			%  required scale factor
selectfont			%  set as current font
1.5 inch 0.5 inch moveto	%  set current point
52 rotate			%  rotate coordinate system
(PostScript!) show		%  image title
showpage			%  display page
