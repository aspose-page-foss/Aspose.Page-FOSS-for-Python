%!PS

%	This example appears in section "Show String with Track Kerning" in
%	Chapter 3 - "Text".
%

/inch { 72 mul } def				%  define inch procedure

/DrawRect {					%  stack = x y width height
	4 2 roll moveto				%  move to x, y 
	1 index 0 rlineto			%  bottom edge
	0 exch rlineto				%  right edge
	neg 0 rlineto				%  top edge
	closepath				%  close rectangle
} def

/BusinessCardOutline {
	0.66666 setgray				%  drop shadow
	8 -8 3.5 inch 2.0 inch DrawRect fill
	1 setgray				%  white background
	0 0 3.5 inch 2.0 inch DrawRect fill
	0 setgray
	1 setlinewidth				%  outline of card
	0 0 3.5 inch 2.0 inch DrawRect stroke
} def

BusinessCardOutline				%  draw outline
/Palatino-Roman findfont				%  set current font
36 scalefont setfont
0.25 inch 0.75 inch moveto			%  set current point
(CHEZ) show					%  display first line
/Palatino-Roman findfont				%  set new font
30 scalefont setfont
0.25 inch 0.25 inch moveto			%  reset current point
-2 0 (PIERRE) ashow				%  display second line
showpage					%  display page
