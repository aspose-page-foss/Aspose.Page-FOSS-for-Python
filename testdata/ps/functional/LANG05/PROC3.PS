%!PS

%	This example appears in section "Procedure Definitions"
%	in Chapter 5 - "PostScript Language".
%

/inch { 72 mul } def			%  define inch procedure

/triangle {				%  stack = llx lly
	moveto				%  set current point
	6 inch 0 rlineto		%  first side
	120 rotate 6 inch 0 rlineto	%  second side
	closepath			%  finish shape
} def					%  define triangle procedure

0.5 inch setlinewidth			%  set line width
gsave					%  save graphics state
	1.25 inch 3.5 inch		%  lower-left corner of triangle
	triangle stroke			%  right side up triangle
grestore				%  restore graphics state
0 11 inch translate			%  translate to upper left corner
1 -1 scale				%  invert coordinate system
gsave					%  save graphics state
	1.25 inch 4 inch		%  lower-left corner of triangle
	triangle stroke			%  upside down triangle
grestore				%  restore graphics state
showpage				%  display page
