%!PS

%	This example appears in section "Procedure Definitions"
%	in Chapter 5 - "PostScript Language".
%

/inch { 72 mul } def		%  define inch procedure
4.25 inch 5.5 inch translate	%  center of page
24				%  number of times to repeat
{				%  start procedure
	0 0 moveto		%  set current point
	4 inch 0 rlineto	%  draw line
	15 rotate		%  rotate
} repeat			%  loop
stroke				%  stroke starburst
showpage			%  display page
