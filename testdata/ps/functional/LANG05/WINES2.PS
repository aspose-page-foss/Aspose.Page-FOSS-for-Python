%!PS

%	This example appears in section "Relational Operators with Strings"
%	in Chapter 5 - "PostScript Language".
%

/bibubble {				%  stack = unsorted array operator
    /compare exch def			%  remember operator
    /Array exch def			%  remember array
    0 1 Array length 2 sub {		%  loop through array
	-1 0 {				%  and again
	    /i exch def			%  define loop variable
	    Array i 2 getinterval	%  get array with two strings
	    aload pop			%  get two strings
	    2 copy			%  copy them
	    compare {			%  compare them
		exch 2 array astore	%  put strings in small array
		Array exch i exch	%  swap them
		putinterval
	    } { pop pop } ifelse	%  otherwise clean up stack
	} for
    } for
    Array				%  return sorted array
} def

/inch { 72 mul } def			%  define inch procedure
/Palatino-Roman findfont		%  choose font
0.75 inch scalefont setfont
/base 9.5 inch def			%  y location of first wine
[
	(Chardonnay)
	(Cabernet)
	(Cabernet Sauvignon)
	(Chianti)
	(Merlot)
	(Pinot Noir)
	(Champagne)
	(Gamay)
	(Zinfandel)
]					%  define array of strings
{ lt } bibubble				%  sort in descending order
{
	0.5 inch base moveto		%  set current point
	show				%  show string
	/base base 1.0 inch sub def	%  move y position
} forall				%  for all strings in the array
showpage				%  display page
