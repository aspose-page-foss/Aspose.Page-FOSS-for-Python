%!PS

%	This example appears in section "Simple Loop" in
%	Chapter 5 - "PostScript Language".
%

/triangle {				%  stack = llx lly
	moveto				%  set current point
	3 inch 0 rlineto		%  first side
	120 rotate 3 inch 0 rlineto	%  second side
	closepath			%  finish shape
} def					%  define triangle procedure

/whileloop {				%  stack = test procedure
	/proc exch def			%  remember procedure
	/test exch def			%  remember test
	{				%  start loop
		test			%  perform the test
		{ proc }		%  if true--exec procedure
		{ exit }		%  else exit loop
		ifelse			%  end of if
	} loop				%  forever
} def

/inch { 72 mul } def			%  define inch procedure
4.25 inch 5.5 inch translate		%  center of page
{ currentgray 1 lt }			%  while gray less than 1
{
	0.875 inch 0.875 inch		%  lower-left corner
	gsave triangle fill grestore	%  fill triangle
	currentgray 0.125 add setgray	%  update gray
	45 rotate			%  turn user space
} whileloop				%  loopty loop
showpage				%  display page
