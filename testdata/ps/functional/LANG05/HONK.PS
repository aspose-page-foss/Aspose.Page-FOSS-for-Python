%!PS

%	This example appears in the introductory section of
%	in Chapter 5 - "PostScript Language".
%

/Heart {					%  define heart procedure
	170 415 moveto
	90 415 0 365 -20 255 curveto
	-50 365 -140 415 -220 415 curveto
	-320 415 -420 315 -400 175 curveto
	-380 45 -130 -165 -30 -455 curveto
	60 -175 290 -35 350 175 curveto
	380 315 270 415 170 415 curveto
	closepath
} def

/inch { 72 mul } def				%  define inch procedure
/Palatino-Bold findfont 64 scalefont setfont	%  select font
0.25 inch 5.5 inch moveto			%  set current point
(PS    ) show					%  show PS
currentpoint 2 copy 20 add 			%  remember current point
gsave						%  draw heart
	translate 0.096 dup scale
	Heart fill
grestore
moveto						%  reset current point
(     { Honk! }  if) show			%  show honk message
showpage					%  display page
