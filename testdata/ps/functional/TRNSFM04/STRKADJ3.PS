%!PS

%	This example appears in section "Accurate Positioning"
%	in Chapter 4 - "Transformations".
%

/m {					%  stack = x, y
    transform 				%  user space to device space
    0.25 sub round 0.25 add exch 	%  y to 1/4 pixel point
    0.25 sub round 0.25 add exch 	%  x to 1/4 pixel point
    itransform 				%  device space back to user space
    moveto 				%  set current point
} def
/l {					%  stack = x, y
    transform 				%  user space to device space
    0.25 sub round 0.25 add exch 	%  y to 1/4 pixel point
    0.25 sub round 0.25 add exch 	%  x to 1/4 pixel point
    itransform 				%  device space back to user space
    lineto 				%  add line segment
} def

/inch { 72 mul } def			%  define inch procedure
1 1 20 {
    8.5 inch 20 div mul 		%  x coordinate
    dup 				%  save for drawing line
    1 inch 				%  y coordinate
    m 					%  set current point
    9 inch l				%  add line segment
    0.24 setlinewidth			%  one pixel line at 300 dpi
} for
stroke					%  paint the path
showpage				%  display page
