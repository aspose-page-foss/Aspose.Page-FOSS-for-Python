%!PS
%	This example appears in section "Images with Filters"
%	in Chapter 9 - "Images".
%
%	Caveats:	Requires PostScript Level 2.

/inch { 72 mul } def				%  define inch procedure
/temp 16 string def				%  string for temporary results
1.25 inch 2.5 inch translate			%  set origin
6 inch 6 inch scale				%  scale image large
<<						%  start image dictionary
    /ImageType 1				%  required
    /Width 64					%  bits per scan line
    /Height 64					%  number of scan lines
    /BitsPerComponent 1				%  depth of image
    /ImageMatrix [ 64 0 0 64 0 0 ]		%  image matrix
    /DataSource currentfile /ASCII85Decode filter
    /Decode [ 0 1 ]				%  transfer function
>>						%  end image dictionary
						%  image operation
image
