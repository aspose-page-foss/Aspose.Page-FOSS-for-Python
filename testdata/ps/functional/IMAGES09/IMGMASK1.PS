%!PS

%	This example appears in section "Image Masks"
%	in Chapter 9 - "Images".
%

/inch { 72 mul } def			%  define inch procedure
0 0 moveto				%  set current point
8.5 inch 0 rlineto			%  bottom of rectangle
0 11 inch rlineto			%  right side
-8.5 inch 0 rlineto			%  top
closepath				%  finish the shape
0.9 setgray fill			%  light gray background
0.0 setgray				%  reset color to black
/temp 16 string def			%  string for temporary results
1.25 inch 2.5 inch translate		%  set origin
6 inch 6 inch scale			%  scale image large
64 64 1 				%  width, height, depth
[ 64  0  0  64  0  0 ]			%  image matrix
{ currentfile temp readhexstring pop }	%  image procedure
					%  image operation
image
