%!PS

%	This example appears in section "Filling Multiple Rectangles"
%	in Chapter 2 - "Paths and Painting".
%
%	Caveats:	Requires PostScript Level 2.

/inch { 72 mul } def			%  define inch procedure
0.5 setgray				%  set medium gray
[					%  start numarray
    1 inch 1.0 inch 3 inch 3 inch	%  rectangle descriptions
    2 inch 2.5 inch 3 inch 3 inch
    3 inch 4.0 inch 3 inch 3 inch
    4 inch 5.5 inch 3 inch 3 inch
    5 inch 7.0 inch 3 inch 3 inch
]					%  end of numarray
rectfill				%  paint the area
showpage				%  display page
