%!PS

%	This example appears in section "Stroking Rectangles"
%	in Chapter 2 - "Paths and Painting".
%
%	Caveats:	Requires PostScript Level 2.

/inch { 72 mul } def	%  define inch procedure
1 inch 1 inch		%  lower-left corner
6 inch 8 inch		%  width and height
rectstroke		%  stroke the path
showpage		%  display page
