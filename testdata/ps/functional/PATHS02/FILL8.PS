%!PS

%	This example appears in section "Filling Rules"
%	in Chapter 2 - "Paths and Painting".
%

/inch { 72 mul } def				%  define inch procedure

4.25 inch 5.5 inch translate			%  move coordinate system
1 1.25 scale					%  scale coordinate system
newpath 0 0 4 inch 0 360 arc closepath		%  draw outer circle
0.50 setgray fill				%  fill with medium gray
newpath 0 0 3 inch 0 360 arc closepath		%  draw next circle
1 setgray fill					%  fill with white
newpath 0 0 2 inch 0 360 arc closepath		%  draw next circle
0.50 setgray fill				%  fill with medium gray
newpath 0 0 1 inch 0 360 arc closepath		%  draw inner circle
1 setgray eofill				%  fill with white
showpage					%  display page
