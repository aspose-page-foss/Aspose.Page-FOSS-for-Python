%!PS

%	This example appears in section "HSB Color Model"
%	in Chapter 13 - "Color and Halftones".
%

/inch { 72 mul } def				%  define inch procedure
/point_right 0 def				%  set of definitions and
/point_left  1 def				%  procedures to draw arrows
/point_up    2 def
/point_down  3 def

/arrow {					%  x  y  length  direction
    4 2 roll					%  length  direction  x  y
    /m matrix currentmatrix def
    translate					%  length  direction
    0 0 moveto					%  length  direction
    dup						%  length  direction  direction
    [ 
        {  0 24 -42 -12 }			%  right
        {  0 24  42 -12 }			%  left
        { 24  0 -12 -42 }			%  up
        { 24  0 -12  42 }			%  down
    ] exch get exec rlineto rlineto closepath
    fill					%  length  direction
    0 0 moveto
    [
        { neg 0      }
        {     0      }
        { neg 0 exch }
        {     0 exch }
    ] exch get exec rlineto stroke
    m setmatrix
} def

/right_arrow {					%  x y length
    point_right arrow
} def
 
/left_arrow {					%  x y length
    point_left arrow
} def
 
/down_arrow {					%  x y length
    point_down arrow
} def

/up_arrow {					%  x y length
    point_up arrow
} def

/Palatino-Italic findfont 48 scalefont setfont	%  establish current font
4.25 inch 5.5 inch translate			%  move origin
gsave						%  save graphics state
/width .012 360 mul def				%  width of concentric circles
/hue 1 3 div def				%  establish green color
17 setlinewidth					%  thick line width
/radius 4.25 inch def				%  set radius of outer circle

100 -1 1 {					%  loop to draw circle
    hue exch 100 div 1.0 sethsbcolor
    newpath
    0 0 radius 0 360 arc stroke
    /radius radius 4.25 inch 100 div sub def
} for
grestore					%  restore graphics state

0 setgray					%  set black color
3 setlinewidth					%  change line width
-4.25 inch 0 inch 4.25 inch left_arrow		%  draw left pointing arrow
-2.75 inch .25 inch moveto (Saturation) show	%  show label

showpage					%  display page
