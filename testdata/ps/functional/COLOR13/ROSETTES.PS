%!PS

%	This example appears in section "Choosing an Angle for Color Halftone
%	Screens" in Chapter 13 - "Color and Halftones".
%

/inch { 72 mul } def				%  define inch procedure
/gap 0.5 inch def				%  space between dots
4.25 inch 5.5 inch translate			%  move origin
1 setlinecap					%  set line cap feature
15 setlinewidth					%  do thick line width
[ 0 gap ] 0 setdash				%  set up dash pattern

/grid {						%  procedure to draw grid
	0 gap 6.0 inch {
		-3 inch add -3 inch moveto
		0 inch 6.0 inch rlineto
		stroke
	} for
} def

gsave						%  save graphics state
	45 rotate grid				%  black
grestore					%  restore graphics state
gsave						%  save graphics state
	15 rotate 1 0 0 0 setcmykcolor grid	%  cyan
grestore					%  restore graphics state
gsave						%  save graphics state
	75 rotate 0 1 0 0 setcmykcolor grid	%  magenta
grestore					%  restore graphics state
gsave						%  save graphics state
	0 0 1 0 setcmykcolor grid		%  yellow
grestore					%  restore graphics state
showpage					%  display page
