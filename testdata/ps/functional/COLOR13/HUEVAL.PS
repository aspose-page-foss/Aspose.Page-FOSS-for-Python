%!PS

%       This example appears in section "HSB Color Model"
%       in Chapter 13 - "Color and Halftones".
%

/inch { 72 mul } def                            %  define inch procedure


/Palatino-Italic findfont                       %  establish current font
36 scalefont setfont
3.5 inch 8.4 inch moveto                        %  set current point
(0.0) show                                      %  0.0 = red
4.4 inch 8.4 inch moveto                        %  set current point
(1.0) show                                      %  1.0 = red
0.05 inch 1.3 inch moveto                       %  set current point
(0.333) show                                    %  0.333 = green
7.3 inch 1.3 inch moveto                        %  set current point
(0.667) show                                    %  0.6667 = blue

newpath                                         %  clear current path
gsave                                           %  remember graphics state
    4.25 inch 4.25 inch translate               %  orgin to middle of page
    0 0 1 inch 0 360 arc                        %  draw inner circle
    0 0 4 inch 360 0 arcn                       %  draw outer circle
    clip                                        %  use as clip path

    newpath                                     %  clear current path
    /width 0.012 360 mul def                    %  width of slice
    0 .003 1 {                                  %  start for loop
        1 1 sethsbcolor                         %  set hue
        0 0 width 4.25 inch rectfill            %  fill a slice
        0.003 360 mul rotate                    %  rotate for next slice
    } for                                       %  end for loop
grestore                                        %  restore graphics state

newpath                                         %  clear current path
0 setgray                                       %  color to black
3 setlinewidth
4.25 inch 4.25 inch 1 inch 0 360 arc stroke     %  line around inner circle
4.25 inch 4.25 inch 4 inch 0 360 arc stroke     %  line around outer circle

newpath                                         %  clear current path
gsave                                           %  remember graphics state
    4.25 inch 4.25 inch translate               %  orgin to middle of page
    3 {                                         %  start repeat loop
        0 16 moveto                             %  set current point
        0 inch 4.25 inch lineto stroke          %  draw radial line
        120 rotate                              %  rotate for next line
    } repeat                                    %  end repeat loop
grestore                                        %  restore graphics state
showpage                                        %  display page
