%!PS

%	This example appears in section "Composite Characters"
%	in Chapter 10 - "Fonts".
%

/inch { 72 mul } def			%  define inch procedure
/DesignSize 1000 def			%  character design space
/PointSize 10 inch def			%  size for character
/ScaleFactor PointSize DesignSize div def
%/Optima findfont			%  find required font
/Helvetica findfont			%  find required font
PointSize scalefont			%  scale to required size
setfont					%  make current font
1 inch 1 inch translate			%  position origin
0 0 moveto				%  set current point
(A) show				%  show "A" character
147 ScaleFactor mul			%  compute x position
206 ScaleFactor mul			%  compute y position
moveto					%  set current point
(\312) show				%  show ring character
showpage				%  display page
