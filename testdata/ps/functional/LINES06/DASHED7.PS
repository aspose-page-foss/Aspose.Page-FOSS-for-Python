%!PS

%	This example appears in section "Dashed Line Styles with Line Caps"
%	in Chapter 6 - "Line Weights and Line Styles".
%

/inch { 72 mul } def			%  define inch procedure
4.25 inch 5.5 inch 3 inch 0 360 arc	%  draw circle
closepath				%  finish the shape
gsave					%  push graphics state
	0.50 setgray fill		%  fill with medium gray
grestore				%  pop graphics state
[ 0 3 inch 2 3.14159 mul mul 0.5 inch div ] 0 setdash
0.25 inch setlinewidth			%  set fat line width
1 setlinecap				%  round line caps
stroke					%  paint the path
showpage				%  display page
